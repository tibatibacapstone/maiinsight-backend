{
  "name": "maiinsight-backend",
  "version": "1.0.0",
  "description": "Express.js API for MaiinSight customer segmentation and marketing insights.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src",
    "test": "node --test",
    "seed": "node prisma/seed.js"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "client": {
      "output": "src/prisma/client"
    },
    "migrations": {
      "directory": "prisma/migrations"
    },
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "express",
    "api",
    "customer-segmentation",
    "rfm",
    "k-means"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tibatibacapstone/maiinsight-backend.git"
  },
  "bugs": {
    "url": "https://github.com/tibatibacapstone/maiinsight-backend/issues"
  },
  "homepage": "https://github.com/tibatibacapstone/maiinsight-backend#readme",
  "allowScripts": {
    "@google/genai@2.6.0": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true,
    "protobufjs@7.6.1": true
  }
}
