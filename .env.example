NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
APP_URL=http://localhost:3000
DATABASE_URL=
JWT_SECRET=

# SMTP configuration for invitation emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MaiinSight <no-reply@maiin.com>

# Recommended for capstone/demo: Gemini is the default AI provider.
# Set AI_PROVIDER=azure only if you want to use Azure OpenAI instead.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional Azure OpenAI configuration for MaiinSight AI Strategy Assistant
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Meta Graph / Instagram Business configuration for InstaSight
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=
META_API_VERSION=v25.0
META_API_BASE_URL=https://graph.facebook.com
