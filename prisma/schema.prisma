generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  operational
  management
  it_support
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  name      String
  password  String
  role      Role          @default(operational)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  logs      ActivityLog[]
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  role      Role
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum ImportStatus {
  uploaded
  processing
  completed
  failed
}

model ImportBatch {
  id           Int          @id @default(autoincrement())
  fileName     String
  rowCount     Int          @default(0)
  headers      Json
  status       ImportStatus @default(uploaded)
  errorMessage String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  rawTransactions      RawTransactionTable[]
  facilityTransactions FacilityTransaction[]

  @@map("import_batches")
}

model RawTransactionTable {
  id           Int      @id @default(autoincrement())
  batchId      Int
  rowNumber    Int
  data         Json
  status       String   @default("raw")
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("raw_transaction_table")
}

model Customer {
  id                    Int      @id @default(autoincrement())
  customerKey           String   @unique @db.VarChar(191)
  name                  String?  @db.VarChar(191)
  email                 String?  @db.VarChar(191)
  phone                 String?  @db.VarChar(50)
  customerProfile       Json?
  customerKeyType       String   @db.VarChar(50)
  customerKeyConfidence Float?   @db.Double
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  facilityTransactions FacilityTransaction[]

  @@map("customers")
}

model FacilityTransaction {
  id                    Int       @id @default(autoincrement())
  batchId               Int
  rawRowId              Int
  rowNumber             Int
  orderId               String?   @db.VarChar(100)
  customerId            Int?
  customerKey           String    @db.VarChar(191)
  customerName          String?   @db.VarChar(191)
  normalizedName        String?   @db.VarChar(191)
  normalizedEmail       String?   @db.VarChar(191)
  normalizedPhone       String?   @db.VarChar(50)
  customerKeyType       String?   @db.VarChar(50)
  customerKeyConfidence String?   @db.VarChar(50)
  nama                  String?   @db.VarChar(191)
  email                 String?   @db.VarChar(191)
  noTelepon             String?   @db.VarChar(50)
  customerProfile       String?   @db.VarChar(100)
  tanggalTransaksi      DateTime?
  tanggalMain           DateTime?
  jamMain               String?   @db.VarChar(50)
  transactionDate       DateTime?
  playDate              DateTime?
  playTime              String?   @db.VarChar(50)
  startHour             String?   @db.VarChar(10)
  endHour               String?   @db.VarChar(10)
  durationHours         Float
  venue                 String?   @db.VarChar(100)
  lapangan              String?   @db.VarChar(100)
  court                 String    @db.VarChar(100)
  courtType             String?   @db.VarChar(50)
  hargaBersih           Decimal?  @db.Decimal(14, 2)
  addOns                String?   @db.Text
  hargaAddOns           Decimal?  @db.Decimal(14, 2)
  netRevenue            Decimal   @db.Decimal(14, 2)
  addOnRevenue          Decimal   @db.Decimal(14, 2)
  tipeVoucher           String?   @db.VarChar(100)
  hargaVoucher          Decimal?  @db.Decimal(14, 2)
  voucherDiscount       Decimal   @db.Decimal(14, 2)
  status                String?   @db.VarChar(100)
  promoName             String?   @db.VarChar(191)
  sportPurpose          String?   @db.VarChar(191)
  description           String?   @db.Text
  reschedule            String?   @db.VarChar(50)
  promosi               String?   @db.Text
  keperluan             String?   @db.VarChar(100)
  deskripsi             String?   @db.Text
  period                String?   @db.VarChar(20)
  playTimeGroup         String?   @db.VarChar(30)
  bookingType           String    @db.VarChar(50)
  validBooking          Boolean   @default(false)
  bookingEventKey       String    @db.VarChar(255)
  bookingRangeKey       String    @db.VarChar(255)
  rawData               Json?
  createdAt             DateTime  @default(now())

  batch           ImportBatch      @relation(fields: [batchId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  courtHourUsages CourtHourUsage[]

  @@index([batchId])
  @@index([rawRowId])
  @@index([customerId])
  @@index([orderId])
  @@index([nama])
  @@index([email])
  @@index([period])
  @@index([tanggalMain])
  @@index([status])
  @@index([playTimeGroup])
  @@index([playDate])
  @@index([courtType])
  @@index([bookingType])
  @@index([validBooking])
  @@index([bookingEventKey])
  @@index([bookingRangeKey])
  @@map("facility_transactions")
}

model CourtHourUsage {
  id            Int      @id @default(autoincrement())
  transactionId Int
  batchId       Int
  playDate      DateTime
  hourStart     String   @db.VarChar(10)
  court         String   @db.VarChar(100)
  courtType     String?  @db.VarChar(50)
  courtHourKey  String   @unique @db.VarChar(191)
  hourlyRevenue Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())

  transaction FacilityTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([batchId])
  @@index([playDate])
  @@index([hourStart])
  @@index([courtType])
  @@map("court_hour_usages")
}

model SegmentationRun {
  id                Int      @id @default(autoincrement())
  runDate           DateTime @default(now())
  updatedAt         DateTime @updatedAt
  method            String   @default("RFM_KMEANS") @db.VarChar(50)
  kValue            Int      @default(0)
  totalCustomers    Int      @default(0)
  filterMonth       String?  @db.VarChar(20)
  filterYear        Int?
  filterPeriodType  String?  @db.VarChar(10)
  filterCourtType   String?  @db.VarChar(50)
  filterBookingType String?  @db.VarChar(50)
  status            String   @default("running") @db.VarChar(50)
  errorMessage      String?  @db.Text
  silhouetteScore   Float?
  kEvaluation       Json?

  customerScores  CustomerRfmScore[]
  clusterProfiles ClusterProfile[]

  @@index([runDate])
  @@index([status])
  @@index([filterYear, filterMonth, filterPeriodType])
  @@index([filterCourtType, filterBookingType])
  @@map("segmentation_runs")
}

model CustomerRfmScore {
  id                  Int      @id @default(autoincrement())
  runId               Int
  customerKey         String   @db.VarChar(191)
  customerName        String?  @db.VarChar(191)
  bookingTypeDominant String?  @db.VarChar(50)
  recency             Int
  frequency           Int
  monetary            Float
  rScore              Int
  fScore              Int
  mScore              Int
  clusterId           Int
  segmentName         String   @db.VarChar(100)
  createdAt           DateTime @default(now())

  run SegmentationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, customerKey])
  @@index([runId])
  @@index([customerKey])
  @@index([segmentName])
  @@index([clusterId])
  @@map("customer_rfm_scores")
}

model ClusterProfile {
  id                 Int      @id @default(autoincrement())
  runId              Int
  clusterId          Int
  segmentName        String   @db.VarChar(100)
  segmentDescription String?  @db.Text
  labelReason        String?  @db.Text
  customerCount      Int
  avgRecency         Float
  avgFrequency       Float
  avgMonetary        Float
  avgRScore          Float?
  avgFScore          Float?
  avgMScore          Float?
  createdAt          DateTime @default(now())

  run SegmentationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, clusterId])
  @@index([runId])
  @@index([segmentName])
  @@map("cluster_profiles")
}

model PlaytimeMlRun {
  id             Int     @id @default(autoincrement())
  period         String? @db.VarChar(20)
  algorithm      String  @default("KMeans") @db.VarChar(50)
  clusterCount   Int
  totalCustomers Int
  totalSessions  Int
  status         String  @default("completed") @db.VarChar(50)
  errorMessage   String? @db.Text

  sessionByTime Json?
  heatmapData   Json?
  topHourData   Json?

  createdAt DateTime @default(now())

  customerSegments PlaytimeCustomerSegment[]
  segmentSummaries PlaytimeSegmentSummary[]

  @@map("playtime_ml_runs")
}

model PlaytimeCustomerSegment {
  id    Int @id @default(autoincrement())
  runId Int

  customerName String @db.VarChar(191)

  sesiPagi  Int
  sesiSiang Int
  sesiMalam Int
  totalSesi Int

  ratioPagi  Float
  ratioSiang Float
  ratioMalam Float

  playtimeCluster Int
  playtimeSegment String  @db.VarChar(100)
  activityLevel   String? @db.VarChar(100)

  run PlaytimeMlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([customerName])
  @@index([playtimeSegment])
  @@map("playtime_customer_segments")
}

model PlaytimeSegmentSummary {
  id    Int @id @default(autoincrement())
  runId Int

  playtimeCluster Int
  playtimeSegment String @db.VarChar(100)

  totalCustomers Int

  avgRatioPagi  Float
  avgRatioSiang Float
  avgRatioMalam Float

  avgSesiPagi  Float
  avgSesiSiang Float
  avgSesiMalam Float
  avgTotalSesi Float

  run PlaytimeMlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([playtimeSegment])
  @@map("playtime_segment_summaries")
}

model MetaRawResponse {
  id           String   @id @default(cuid()) @db.VarChar(30)
  source       String   @db.VarChar(100)
  endpoint     String   @db.Text
  method       String   @default("GET") @db.VarChar(20)
  params       Json?
  responseJson Json?
  status       String   @db.VarChar(50)
  errorMessage String?  @db.Text
  fetchedAt    DateTime @default(now())

  @@map("meta_raw_responses")
}

model InstagramAccount {
  id             String   @id @default(cuid()) @db.VarChar(30)
  igUserId       String   @unique @db.VarChar(100)
  username       String?  @db.VarChar(100)
  name           String?  @db.VarChar(150)
  followersCount Int?
  followsCount   Int?
  mediaCount     Int?
  rawJson        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  media            InstagramMedia[]
  accountInsights  InstagramAccountInsight[]
  snapshots        InstagramAccountSnapshot[]
  audienceInsights InstagramAudienceInsight[]

  @@map("instagram_accounts")
}

model InstagramAccountSnapshot {
  id             String   @id @default(cuid()) @db.VarChar(30)
  accountId      String   @db.VarChar(30)
  followersCount Int?
  followsCount   Int?
  mediaCount     Int?
  snapshotDate   DateTime
  rawJson        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, snapshotDate])
  @@map("instagram_account_snapshots")
}

model InstagramMedia {
  id               String    @id @default(cuid()) @db.VarChar(30)
  igMediaId        String    @unique @db.VarChar(100)
  accountId        String    @db.VarChar(30)
  caption          String?   @db.Text
  mediaType        String?   @db.VarChar(50)
  mediaProductType String?   @db.VarChar(50)
  mediaUrl         String?   @db.Text
  thumbnailUrl     String?   @db.Text
  permalink        String?   @db.Text
  postedAt         DateTime?
  rawJson          Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  account  InstagramAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  insights InstagramMediaInsight[]

  @@map("instagram_media")
}

model InstagramMediaInsight {
  id          String   @id @default(cuid()) @db.VarChar(30)
  mediaId     String   @db.VarChar(30)
  metricName  String   @db.VarChar(100)
  metricValue Float?
  period      String   @default("lifetime") @db.VarChar(50)
  insightDate DateTime
  rawJson     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  media InstagramMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, metricName, insightDate, period])
  @@index([metricName])
  @@map("instagram_media_insights")
}

model InstagramAccountInsight {
  id          String   @id @default(cuid()) @db.VarChar(30)
  accountId   String   @db.VarChar(30)
  metricName  String   @db.VarChar(100)
  metricValue Float?
  period      String   @db.VarChar(50)
  insightDate DateTime
  rawJson     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, metricName, insightDate, period])
  @@index([metricName])
  @@map("instagram_account_insights")
}

model InstagramAudienceInsight {
  id             String   @id @default(cuid()) @db.VarChar(30)
  accountId      String   @db.VarChar(30)
  metricName     String   @db.VarChar(100)
  breakdownType  String   @db.VarChar(50)
  breakdownValue String   @db.VarChar(191)
  metricValue    Float?
  period         String   @db.VarChar(50)
  insightDate    DateTime
  rawJson        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, metricName, breakdownType, breakdownValue, insightDate, period])
  @@map("instagram_audience_insights")
}

model InstagramContentSummary {
  id                 String    @id @default(cuid()) @db.VarChar(30)
  mediaId            String    @db.VarChar(30)
  summary            String?   @db.Text
  performanceInsight String?   @db.Text
  recommendation     String?   @db.Text
  generatedBy        String?   @db.VarChar(100)
  generatedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([mediaId])
  @@map("instagram_content_summaries")
}

model MetaSyncLog {
  id         String    @id @default(cuid()) @db.VarChar(30)
  syncType   String    @db.VarChar(100)
  status     String    @db.VarChar(50)
  message    String?   @db.Text
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@map("meta_sync_logs")
}


